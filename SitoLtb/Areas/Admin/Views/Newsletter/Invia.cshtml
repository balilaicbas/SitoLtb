@model SitoLtb.ViewModels.SendNewsletterVM
@{
    ViewData["Title"] = "Invia Newsletter";
}

<main>
    <div class="Title-list-of-users">
        <h4>Invia Newsletter</h4>
        <a asp-action="Index" class="btn-create" style="background:#6c757d">
            <i class="fas fa-arrow-left me-1"></i> Torna agli iscritti
        </a>
    </div>

    @if (TempData["Err"] != null)
    {
        <div class="alert alert-danger mb-3">@TempData["Err"]</div>
    }

    <div style="max-width:760px; margin-top:24px;">
        <form asp-action="Invia" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Oggetto" class="form-label fw-semibold">Oggetto</label>
                <input asp-for="Oggetto" class="form-control" placeholder="Oggetto della newsletter" />
                <span asp-validation-for="Oggetto" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Corpo" class="form-label fw-semibold">
                    Corpo (HTML supportato)
                </label>
                <textarea asp-for="Corpo" id="newsletterCorpo" class="form-control" rows="16"
                          placeholder="&lt;h2&gt;Ciao!&lt;/h2&gt;&lt;p&gt;Ecco le novità…&lt;/p&gt;"></textarea>
                <span asp-validation-for="Corpo" class="text-danger small"></span>
                <div class="form-text">
                    Puoi usare tag HTML. La mail verrà inviata a tutti gli iscritti attivi.
                </div>
            </div>

            <div class="d-flex gap-3 align-items-center mb-3">
                <button type="button" class="btn btn-outline-secondary" onclick="togglePreview()">
                    <i class="fas fa-eye me-1"></i> Anteprima
                </button>
                <button type="submit" class="btn btn-primary"
                        onclick="return confirm('Sei sicuro di voler inviare la newsletter a tutti gli iscritti?')">
                    <i class="fas fa-paper-plane me-1"></i> Invia a tutti gli iscritti
                </button>
            </div>
        </form>

        <div id="previewBox" style="display:none; border:1px solid #ddd; border-radius:8px; padding:24px; margin-top:12px; background:#fff;">
            <p class="text-muted small mb-2">— Anteprima —</p>
            <div id="previewContent"></div>
        </div>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePreview() {
            const box = document.getElementById('previewBox');
            const html = document.getElementById('newsletterCorpo').value;
            document.getElementById('previewContent').innerHTML = html;
            box.style.display = box.style.display === 'none' ? 'block' : 'none';
        }
    </script>
}
