@{
    ViewData["Title"] = "Seed DB";
}

<main style="padding:40px;max-width:600px">
    <h2 style="color:darkslateblue;margin-bottom:8px">Popola database LTB</h2>
    <p style="color:#666;margin-bottom:24px">
        Crea le tabelle mancanti e inserisce dati di esempio per tornei, soci, giocatori, corsi e fornitori.<br>
        <strong>Le tabelle già popolate vengono saltate senza modifiche.</strong>
    </p>

    <form method="post" asp-action="Run">
        @Html.AntiForgeryToken()
        <button type="submit" class="submit-button">
            Esegui seed
        </button>
    </form>
</main>
