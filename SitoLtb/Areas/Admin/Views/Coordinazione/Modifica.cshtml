@model SitoLtb.ViewModels.CreaProgettoVM
@{
    ViewData["Title"] = "Modifica Progetto";
    var idProgetto = ViewBag.IdProgetto as int?;
}

<div class="coord-page">
    <div class="coord-form-wrap">
        <div class="coord-form-header">
            <i class="fas fa-edit"></i>
            <h2>Modifica Progetto</h2>
        </div>
        <form asp-action="Modifica" asp-route-id="@idProgetto" method="post" class="coord-form">
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

            <div class="form-grid-2">
                <div class="form-group">
                    <label>Titolo *</label>
                    <input asp-for="Titolo" class="form-ctrl" required/>
                </div>
                <div class="form-group">
                    <label>Colore</label>
                    <div class="color-picker-row">
                        <input asp-for="Colore" type="color" class="color-picker-input" id="colorPicker"/>
                        <div class="color-presets">
                            @foreach (var c in new[] { "#4e73df","#1cc88a","#e74a3b","#f6c23e","#36b9cc","#858796","#6f42c1","#fd7e14" })
                            {
                                <button type="button" class="color-preset" style="background:@c"
                                        onclick="document.getElementById('colorPicker').value='@c'"></button>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label>Descrizione</label>
                <textarea asp-for="Descrizione" class="form-ctrl" rows="3"></textarea>
            </div>

            <div class="form-grid-3">
                <div class="form-group">
                    <label>Data Inizio *</label>
                    <input asp-for="DataInizio" type="date" class="form-ctrl" required/>
                </div>
                <div class="form-group">
                    <label>Scadenza</label>
                    <input asp-for="DataScadenza" type="date" class="form-ctrl"/>
                </div>
                <div class="form-group">
                    <label>Stato</label>
                    <select asp-for="Stato" class="form-ctrl">
                        <option value="0">Attivo</option>
                        <option value="1">Completato</option>
                        <option value="2">Sospeso</option>
                    </select>
                </div>
            </div>

            @if (Model.UtentiDisponibili.Any())
            {
                <div class="form-group">
                    <label>Referente</label>
                    <select asp-for="ReferenteId" class="form-ctrl">
                        <option value="">— Seleziona referente —</option>
                        @foreach (var u in Model.UtentiDisponibili)
                        {
                            <option value="@u.UserId">@u.Nome (@u.Email)</option>
                        }
                    </select>
                </div>
            }

            <div class="coord-form-footer">
                <a asp-action="Dettaglio" asp-route-id="@idProgetto" class="btn-det btn-det--back">
                    <i class="fas fa-arrow-left"></i> Annulla
                </a>
                <button type="submit" class="coord-submit-btn"><i class="fas fa-save"></i> Salva Modifiche</button>
            </div>
        </form>
    </div>
</div>
