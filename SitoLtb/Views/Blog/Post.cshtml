@model SitoLtb.ViewModels.BlogPostVM

@{
    string Bg(string? img) =>
        string.IsNullOrWhiteSpace(img)
            ? Url.Content("~/images/placeholder.jpg")
            : Url.Content("~/" + img.TrimStart('/'));
}

<section class="blog-container blog-post-page">

    <!-- TITOLO -->
    <h1 class="blog-post-title">@Model.Title</h1>

    <!-- IMMAGINE -->
    <div class="blog-post-image-wrapper">
        <div class="blog-image blog-post__image"
             style="background-image:url('@Bg(Model.ThumbnailUrl)');">
        </div>
    </div>

    <!-- META -->
    <div class="blog-post__meta">
        Posted by <a href="#!" class="blog-post__author">@Model.AuthorName</a>
        on @Model.CreatedDate.ToShortDateString()
    </div>

    <!-- TESTO -->
    <article class="blog-post__content">
        @Html.Raw(Model.Description)
    </article>

</section>

@if (Model.RelatedPosts.Any())
{
    <section class="related-posts">
        <div class="related-posts__header">
            <h2 class="related-posts__title">Potrebbe anche interessarti</h2>
            <div class="related-posts__nav">
                <button class="related-nav" id="relatedPrev" aria-label="Precedente">&#8249;</button>
                <button class="related-nav" id="relatedNext" aria-label="Successivo">&#8250;</button>
            </div>
        </div>

        <div class="related-slider" id="relatedSlider">
            @foreach (var post in Model.RelatedPosts)
            {
                <a class="related-card" href="/Blog/@post.Url">
                    <div class="related-card__img"
                         style="background-image:url('@Bg(post.ThumbnailUrl)');">
                        <span class="related-card__overlay"></span>
                    </div>
                    <div class="related-card__body">
                        <h3 class="related-card__title">@post.Title</h3>
                        <div class="related-card__author">
                            <span class="related-card__author-icon">✍</span>
                            @post.AuthorName
                        </div>
                    </div>
                </a>
            }
        </div>
    </section>

    <script>
        (function () {
            const slider  = document.getElementById('relatedSlider');
            const gap     = 20;
            const step    = () => slider.querySelector('.related-card').offsetWidth + gap;
            document.getElementById('relatedPrev').addEventListener('click', () =>
                slider.scrollBy({ left: -step(), behavior: 'smooth' }));
            document.getElementById('relatedNext').addEventListener('click', () =>
                slider.scrollBy({ left:  step(), behavior: 'smooth' }));
        })();
    </script>
}
