@model SitoLtb.ViewModels.BlogVM
@using X.PagedList
@using SitoLtb.Models

<h1 class="notizie-page-title">Notizie</h1>
@await Html.PartialAsync("_NotizieSection",
        (Title: "In evidenza", Posts: (IPagedList<Post>?)Model.InEvidenza, ViewAllAction: "NotizieInEvidenza")
    )

@await Html.PartialAsync("_NotizieSection",
        (Title: "Tornei", Posts: (IPagedList<Post>?)Model.Tornei, ViewAllAction: "NotizieTornei")
    )

@await Html.PartialAsync("_NotizieSection",
        (Title: "Eventi", Posts: (IPagedList<Post>?)Model.Eventi, ViewAllAction: "NotizieEventi")
    )

@await Html.PartialAsync("_NotizieSection",
        (Title: "CIS", Posts: (IPagedList<Post>?)Model.Cis, ViewAllAction: "NotizieCis")
    )
    