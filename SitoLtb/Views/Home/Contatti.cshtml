@model SitoLtb.ViewModels.ContattiVM
@{
    ViewData["Title"] = "Contatti";
}

<section class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8 col-xl-7">

            <!-- Titolo -->
            <header class="text-center mb-5">
                <h1 class="display-6 fw-bold mb-2">Contatti</h1>
                <p class="text-secondary mb-0">
                    Per informazioni, iscrizioni e attività del Libero Torneificio del Borgo
                </p>
            </header>

            <!-- Telefono -->
            <div class="card shadow-sm mb-4">
                <div class="card-body p-4 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                    <div>
                        <h2 class="h5 fw-bold mb-1">Telefono</h2>
                        <p class="mb-0 text-secondary">Mario Iacomussi</p>
                    </div>
                    <div class="text-md-end">
                        <a href="tel:+393397703130" class="btn btn-primary btn-lg">
                            339 770 3130
                        </a>
                    </div>
                </div>
            </div>

            <!-- Email -->
            <div class="card shadow-sm mb-4">
                <div class="card-body p-4 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                    <div>
                        <h2 class="h5 fw-bold mb-1">Email</h2>
                        <p class="mb-0 text-secondary">Scrivici per qualsiasi informazione</p>
                    </div>
                    <div class="text-md-end">
                        <a href="mailto:info@liberotorneificiodelborgo.it" class="btn btn-outline-primary btn-lg">
                            info@liberotorneificiodelborgo.it
                        </a>
                    </div>
                </div>
            </div>

            <!-- WhatsApp -->
            <div class="card shadow-sm mb-4">
                <div class="card-body p-4 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                    <div>
                        <h2 class="h5 fw-bold mb-1">Gruppo WhatsApp “ChessInfo”</h2>
                        <p class="mb-0 text-secondary">
                            Per essere aggiunti al gruppo informativo
                        </p>
                    </div>
                    <div class="text-md-end">
                        <div class="fw-semibold">Max De Barberis</div>
                        <a href="tel:+39335215178" class="btn btn-success btn-lg mt-2">
                            335 215 178
                        </a>
                    </div>
                </div>
            </div>

            <!-- Social -->
            <div class="card shadow-sm">
                <div class="card-body p-4 p-lg-5">
                    <h2 class="h5 fw-bold mb-4 text-center">Seguici sui social</h2>

                    <div class="d-grid gap-3">

                        <!-- Instagram -->
                        <a href="https://www.instagram.com/scacchidelborgo/"
                           target="_blank" rel="noopener"
                           class="btn btn-outline-dark btn-lg d-flex justify-content-between align-items-center">
                            <span>Instagram</span>
                            <span class="fw-semibold">scacchidelborgo</span>
                        </a>

                        <!-- Facebook -->
                        <a href="https://www.facebook.com/LiberoTorneificioDelBorgo"
                           target="_blank" rel="noopener"
                           class="btn btn-outline-dark btn-lg d-flex justify-content-between align-items-center">
                            <span>Facebook</span>
                            <span class="fw-semibold">Libero Torneificio del Borgo</span>
                        </a>

                    </div>
                </div>
            </div>

        </div>

            @* ── Feedback messaggi ── *@
            @if (TempData["ContattiOk"] != null)
            {
                <div class="alert alert-success mt-4">@TempData["ContattiOk"]</div>
            }
            @if (TempData["ContattiErr"] != null)
            {
                <div class="alert alert-danger mt-4">@TempData["ContattiErr"]</div>
            }
            @if (TempData["NewsletterOk"] != null)
            {
                <div class="alert alert-success mt-4">@TempData["NewsletterOk"]</div>
            }
            @if (TempData["NewsletterErr"] != null)
            {
                <div class="alert alert-danger mt-4">@TempData["NewsletterErr"]</div>
            }

            @* ── Form contatti ── *@
            <div class="card shadow-sm mt-4" id="contact-form">
                <div class="card-body p-4 p-lg-5">
                    <h2 class="h5 fw-bold mb-1">Scrivici un messaggio</h2>
                    <p class="text-secondary mb-4">Ti risponderemo all'indirizzo email che ci fornisci.</p>

                    <form asp-action="Contatti" asp-controller="Home" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                        <div class="mb-3">
                            <label asp-for="Nome" class="form-label fw-semibold">Nome</label>
                            <input asp-for="Nome" class="form-control" placeholder="Il tuo nome" />
                            <span asp-validation-for="Nome" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold">Email</label>
                            <input asp-for="Email" class="form-control" placeholder="tua@email.it" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="mb-4">
                            <label asp-for="Messaggio" class="form-label fw-semibold">Messaggio</label>
                            <textarea asp-for="Messaggio" class="form-control" rows="5"
                                      placeholder="Scrivi qui il tuo messaggio…"></textarea>
                            <span asp-validation-for="Messaggio" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            <i class="fas fa-paper-plane me-2"></i>Invia messaggio
                        </button>
                    </form>
                </div>
            </div>

            @* ── Newsletter ── *@
            <div class="card shadow-sm mt-4 border-0" id="newsletter" style="background:linear-gradient(135deg,#1a1a2e 0%,#16213e 100%);color:#fff;">
                <div class="card-body p-4 p-lg-5">
                    <h2 class="h5 fw-bold mb-1">
                        <i class="fas fa-envelope-open-text me-2" style="color:#e74c3c"></i>Newsletter LTB
                    </h2>
                    <p class="mb-4" style="opacity:.8">
                        Ricevi aggiornamenti su tornei, corsi ed eventi direttamente nella tua casella email.
                    </p>
                    <form asp-action="NewsletterIscriviti" asp-controller="Home" method="post">
                        <div class="row g-2">
                            <div class="col-12 col-sm-4">
                                <input name="Nome" class="form-control" placeholder="Nome (opzionale)" />
                            </div>
                            <div class="col-12 col-sm-5">
                                <input name="Email" type="email" class="form-control" placeholder="tua@email.it" required />
                            </div>
                            <div class="col-12 col-sm-3">
                                <button type="submit" class="btn btn-danger w-100">Iscriviti</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

    </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
